{
  "name": "slack-reminder",
  "version": "0.0.1",
  "description": "A Slack bot that creates scheduled reminders via @mentions",
  "license": "MIT",
  "main": "lib/main.js",
  "scripts": {
    "local": "npx nodemon --watch \"src/**/*.ts\" --exec \"npx ts-node\" src/main.ts",
    "start": "npx tsc && node lib/main.js",
    "build": "npx tsc",
    "format": "npx prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@slack/socket-mode": "^1.3.4",
    "slack-edge": "^0.12.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
